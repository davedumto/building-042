# --- Database (Supabase Postgres) ---
# Get from Supabase: Project Settings -> Database -> Connection string (URI, "Transaction" pooler for serverless).
# For local dev you can also point this at a local Postgres.
DATABASE_URL="postgresql://user:password@host:5432/postgres?schema=public"

# --- WhatsApp community invite (routing target) ---
# Your community/group invite link. Leads are sent here after onboarding.
NEXT_PUBLIC_WHATSAPP_INVITE="https://chat.whatsapp.com/XXXXXXXXXXXXX"

# --- Test-run cap (300-person test) ---
NEXT_PUBLIC_BUILDER_CAP="300"

# --- Public site URL (used to build shareable referral links) ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Email (Nodemailer / SMTP) ---
# Fine for low-volume transactional "you're in" emails during the test.
# Gmail: enable 2FA, then create an App Password (not your login password).
# Leave SMTP_HOST empty to run in "log to console" mode (no real send).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="The Enugu Creative Movement <hello@example.com>"

# --- Admin auth ---
# ADMIN_PASSWORD is what you type on the login screen.
# ADMIN_TOKEN is the secret used to sign the admin session cookie.
ADMIN_PASSWORD="pick-a-strong-password"
ADMIN_TOKEN="change-me-to-a-long-random-string"
